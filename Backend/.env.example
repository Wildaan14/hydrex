# Environment Variables
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hydrex
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/hydrex

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
FROM_NAME=HydrEx Platform
FROM_EMAIL=noreply@hydrex.com
FRONTEND_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Blockchain (optional - for future integration)
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=

